# Copy this file to `.env` and fill in the keys you have. All are OPTIONAL —
# TrendFlow runs without any of them (prices + per-ticker news come from
# yfinance, which needs no key).

# Enables the 🧠 AI Briefing tab (Claude). Get one at:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional extra headline source (https://newsapi.org). Without it, the
# NewsAPI step is simply skipped.
NEWS_API_KEY=

# Optional: raises the GitHub trending API rate limit (60 -> 5000 req/hr).
GITHUB_TOKEN=

# Optional: point at your own ticker universe instead of the default.
# (You can also just drop a `tickers.json` in the project root.)
# TRENDFLOW_TICKERS=/absolute/path/to/tickers.json
